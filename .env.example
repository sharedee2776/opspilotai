# App
NODE_ENV=development
APP_PORT=3000
APP_PUBLIC_URL=https://your-railway-domain.up.railway.app

# Database — use DATABASE_URL in production (Railway reference: ${{Postgres.DATABASE_URL}})
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=opspilot_dev
DB_LOGGING=false

# Redis — use REDIS_URL in production (Railway reference: ${{Redis.REDIS_URL}})
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Slack (optional — app starts without these, just no Slack notifications)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7

# Alert pipeline
ALERT_DEDUP_WINDOW_MINUTES=5
MIN_ALERTS_TO_GROUP=2

# Set to false to skip running SQL migrations on startup (default: runs migrations)
RUN_MIGRATIONS=true
