# Point to your backend API. In dev, the Vite proxy handles /api → localhost:3001.
# In production set this to your Railway backend URL.
VITE_API_URL=https://your-backend.up.railway.app
# Backend API URL (proxied via Vite in dev, set explicitly in production)
VITE_API_URL=

# Firebase — get from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# When VITE_FIREBASE_API_KEY is missing or set to "your-api-key",
# the app falls back to direct email/password login (dev/staging mode).
